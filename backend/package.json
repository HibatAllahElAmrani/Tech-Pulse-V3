{
  "name": "oss-pulse-backend",
  "version": "0.2.0",
  "description": "OSS Pulse - Fastify API + Socket.io + BullMQ workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -m migrations",
    "migrate:up": "node-pg-migrate -m migrations up",
    "migrate:down": "node-pg-migrate -m migrations down",
    "migrate:create": "node-pg-migrate -m migrations create",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/oauth2": "^7.8.1",
    "@fastify/rate-limit": "^9.1.0",
    "@octokit/rest": "^20.1.1",
    "@octokit/graphql": "^7.1.0",
    "bullmq": "^5.13.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.2",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8",
    "@fastify/helmet": "^11.1.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  }
}
