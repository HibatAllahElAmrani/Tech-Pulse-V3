# OSS Pulse backend — variables d'environnement (copie : cp .env.example .env)

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Origine autorisée par CORS (le frontend Vite)
FRONTEND_URL=http://localhost:5173

# PostgreSQL + TimescaleDB (node-pg-migrate lit aussi DATABASE_URL)
DATABASE_URL=postgres://osspulse:osspulse@localhost:5432/osspulse

# Redis (cache + BullMQ + pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Secrets — valeurs de DÉVELOPPEMENT uniquement.
# En production : openssl rand -hex 32 (JWT) / openssl rand -hex 32 (clé AES-256).
JWT_SECRET=dev-only-jwt-secret-change-me-0123456789abcdef
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# GitHub (optionnel — augmente le quota des collecteurs legacy /projects)
# GITHUB_PERSONAL_TOKEN=ghp_xxx
# GITHUB_TOKENS=ghp_xxx,ghp_yyy

# Micro-service IA (non requis pour l'API frontend)
AI_SERVICE_URL=http://localhost:8000
